<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login | Really Real Education</title>
    <link rel="stylesheet" href="/styles/styles.css">
</head>
<body class="volunteer-page">
<div class="page">

  <header class="site-header">
    <div class="site-header-inner">
      <div class="brand">
        <div class="brand-title">Really Real Education</div>
        <div class="brand-tagline">
          An Educational Initiative of
          <a
            href="https://jaltediyefoundation.org"
            target="_blank"
            rel="noopener noreferrer"
            >Jalte Diye Foundation</a
          >
        </div>
      </div>
      <nav class="site-nav">
        <a href="https://reallyrealeducation.org/">Return to Site</a>
      </nav>
    </div>
  </header>

  <!-- LOGIN CONTAINER -->
  <div class="container login-container">

    <div class="top-bar">
      <h1>Admin Login</h1>
    </div>

    <p class="login-subtitle">Restricted access — authorised personnel only.</p>

    <form action="/admin/login" method="POST">

      <label class="field-label" for="username">Email</label>
      <input type="email" id="username" name="username" placeholder="admin@email.com" required>

      <label class="field-label" for="password">Password</label>
      <input type="password" id="password" name="password" placeholder="••••••••" required>

      <button type="submit" class="btn-primary">Login</button>

    </form>

  </div>

  <footer class="footer">
    <div>
      Built by Jalte Diye Foundation for Learners at
      reallyrealeducation.org.
    </div>
    <div class="footer-links">
      <a
        href="https://jaltediyefoundation.org"
        target="_blank"
        rel="noopener noreferrer"
        >Privacy &amp; Terms</a
      >
      <a href="https://reallyrealeducation.org/compliance.html">Compliance</a>
      <a href="https://reallyrealeducation.org/founder.html">Founder's message</a>
    </div>
    <div class="footer-links">
      <a
        class="social-link"
        href="https://www.facebook.com/JalteDiyeFoundation/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Jalte Diye Foundation on Facebook"
      >
        <img class="social-icon" src="/images/Facebook_Logo_Primary.png" alt="Facebook">
      </a>
      <a
        class="social-link"
        href="https://www.instagram.com/jalte_diye_foundation/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Jalte Diye Foundation on Instagram"
      >
        <img class="social-icon" src="/images/Instagram_Glyph_Gradient.png" alt="Instagram">
      </a>
      <a
        class="social-link"
        href="https://www.linkedin.com/company/jalte-diye-foundation/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Jalte Diye Foundation on LinkedIn"
      >
        <img class="social-icon" src="/images/LI-In-Bug.png" alt="LinkedIn">
      </a>
      <a
        class="social-link"
        href="https://x.com/JalteDiyeNPO"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Jalte Diye Foundation on X"
      >
        <img class="social-icon" src="/images/logo-black.png" alt="X">
      </a>
      <a
        class="social-link"
        href="https://www.youtube.com/@JalteDiyeNPO"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Jalte Diye Foundation on YouTube"
      >
        <img class="social-icon" src="/images/yt_icon_red_digital.png" alt="YouTube">
      </a>
    </div>
    <div class="fine-print">
      You can subscribe to us on social media for updates.
    </div>
  </footer>

</div>
</body>
</html>
