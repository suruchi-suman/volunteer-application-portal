<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Login</title>
    <link rel="stylesheet" href="/styles/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body class="volunteer-page">

<!-- NAVBAR -->
<nav class="navbar">
    <h2>Really Real Education</h2>
</nav>

<!-- LOGIN CONTAINER -->
<div class="container login-container">

    <div class="top-bar">
        <h1>Admin Login</h1>
    </div>

    <p class="login-subtitle">Restricted access — authorised personnel only.</p>

    <form action="/admin/login" method="POST">

        <label class="field-label" for="username">Email</label>
        <input type="email" id="username" name="username" placeholder="admin@email.com" required>

        <label class="field-label" for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required>

        <button type="submit" class="btn-primary">Login</button>

    </form>

</div>

</body>
</html>
