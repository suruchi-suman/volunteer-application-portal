<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Volunteer Application | Really Real Education</title>
    <link rel="icon" type="image/png" href="/images/favicon.png">
    <link rel="stylesheet" href="/styles/styles.css">   
</head>
<body class="volunteer-page">
<div class="page">

  <%- include("partials/header.ejs") %>

  <!-- FORM CONTAINER -->
  <div class="container">

    <div class="top-bar">
      <h1>Volunteer Application Form</h1>
    </div>

    <form action="/submit" method="POST" enctype="multipart/form-data">

      <div class="row">
        <input type="text" name="fName" placeholder="First Name*" required>
        <input type="text" name="lName" placeholder="Last Name">
      </div>

      <div class="row">
        <input type="email" name="email" placeholder="Email*" required>
        <input type="text" name="telephone" placeholder="Contact Number*" required>
      </div>

      <select name="volunteerType" id="type" required onchange="toggleFields()">
        <option value="">Select Role</option>
        <option value="technical">Technical</option>
        <option value="non-technical">Non-Technical</option>
      </select>

      <input type="text" name="contribution" placeholder="How would you like to contribute?*" required>

      <!-- TECHNICAL FIELDS -->
      <div id="techFields" class="hidden">
        <input type="file" name="resume" accept="application/pdf" required>
        <input type="text" name="github" placeholder="GitHub Profile*" required>
        <input type="text" name="linkedin" placeholder="LinkedIn Profile*" required>
        <input type="text" name="portfolio" placeholder="Portfolio (Optional)">
      </div>

      <button type="submit" class="btn-primary">Submit Application</button>
    </form>

  </div>

  <%- include("partials/footer.ejs") %>

</div>

<script>
function toggleFields() {
    const type = document.getElementById("type").value;
    const techFields = document.getElementById("techFields");
    const isTechnical = type === "technical";

    techFields.classList.toggle("hidden", !isTechnical);

    // Enable/disable required based on visibility
    techFields.querySelectorAll("input").forEach(input => {
        if (isTechnical) {
            input.setAttribute("required", true);
        } else {
            input.removeAttribute("required");
        }
    });
}
</script>
</body>
</html>
